# App
APP_NAME="Đèn Đá Muối Himalaya API"
DEBUG=True
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database (MySQL)
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/da_muoi_db

# JWT
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

# AI / LLM — OpenCode Zen (OpenAI-compatible)
LLM_PROVIDER=opencode
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash-free

# Legacy / optional providers
HF_TOKEN=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Intent detection (chatbot routing)
INTENT_MODE=multi
INTENT_MIN_CONFIDENCE=0.45
INTENT_DEBUG=false

# Product search (chat recommend)
PRODUCT_SEARCH_MODE=db
PRODUCT_RECOMMEND_LIMIT=6

# Chat session memory
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_MAX_TURNS=8
CHAT_STREAM_ENABLED=true

# Vector DB (ChromaDB)
CHROMA_DB_PATH=./chroma_db

# Embeddings
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-2-preview
EMBEDDING_BATCH_SIZE=32

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/v1/payments/vnpay/return
VNPAY_ORDER_TYPE=other

# MoMo Payment Gateway (sandbox)
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=Himalayan Glow
MOMO_STORE_ID=HimalayanGlow
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8000/api/v1/payments/momo/return
MOMO_IPN_URL=http://localhost:8000/api/v1/payments/momo/ipn
# payWithATM = nhập thẻ/TK ngân hàng | captureWallet = quét QR ví MoMo
MOMO_REQUEST_TYPE=payWithATM