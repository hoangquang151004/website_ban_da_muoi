# =============================================================================
# Python
# =============================================================================

# Bytecode & cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
MANIFEST

# Virtual environments
venv/
.venv/
env/
.env.bak
ENV/

