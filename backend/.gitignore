# Environment & Secrets
# =============================================================================

.env
.env.*
!.env.example

# =============================================================================
# FastAPI / Uvicorn
# =============================================================================

# Upload files (runtime content — không commit lên repo)
static/uploads/*
!static/uploads/.gitkeep

# =============================================================================
